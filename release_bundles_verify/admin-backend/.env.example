# APK Site environment defaults
# Copy this file to .env and adjust per deployment.

# Core service
APK_DIR=./data/apk
APK_PORT=5003
APK_HOST=0.0.0.0
APK_LOG_DIR=./logs
APP_PORTAL_MODE=admin
ADMIN_PORT=5003
PLAYER_PORT=5004
FORUM_PORT=5005
APK_DEBUG=false
APK_SECRET=

# External/public URLs
PUBLIC_URL=
EXTERNAL_DOMAIN=
PLAYER_PUBLIC_URL=
FORUM_PUBLIC_URL=
ADMIN_PUBLIC_URL=
PLAYER_DOMAIN=
FORUM_DOMAIN=
ADMIN_DOMAIN=

# Jenkins
JENKINS_URL=http://localhost:8080
JENKINS_USER=
JENKINS_TOKEN=
JENKINS_JOB_NAME=Android
JENKINS_BUILDS_DIR=./data/jenkins_instances/default/jobs/Android/builds
JENKINS_INSTANCES_DIR=./data/jenkins_instances
JENKINS_WAR_PATH=
JENKINS_DOCKER_IMAGE=jenkins/jenkins:lts-jdk17
JENKINS_CONTAINER_NAME=apk-site-jenkins
JENKINS_DEFAULT_USER=admin
JENKINS_DEFAULT_PASSWORD=admin123

# Security
FORCE_LOGIN=true
INNER_NET=192.168.,10.,127.,26.26.
IP_WHITELIST=
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_LOCKOUT_MINUTES=15

# Storage mode
USE_SQLITE=true
SQLITE_MIRROR_JSON=false
SQLITE_IMPORT_JSON_ON_MISS=false

# Optional email report
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=
REPORT_HOUR=8

# Optional alerting
ALERT_FEISHU_WEBHOOK=
DISK_ALERT_GB=5

# Optional backup schedule
BACKUP_SCHEDULED=true
BACKUP_HOUR=2
BACKUP_RETENTION_COUNT=7
