<?xml version='1.1' encoding='UTF-8'?>
<project>
  <description></description>
  <keepDependencies>false</keepDependencies>
  <properties>
    <hudson.model.ParametersDefinitionProperty>
      <parameterDefinitions>
        <hudson.model.StringParameterDefinition>
          <name>UNITY_VERSION</name>
          <description>Unity 版本 (例如: 6000.3.8f1)</description>
          <defaultValue>6000.3.8f1</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>VERSION_NAME</name>
          <description>版本号 (例如: 1.0.0)</description>
          <defaultValue>1.0.16</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>VERSION_CODE</name>
          <description>版本代码 (例如: 100)</description>
          <defaultValue>100</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>APP_NAME</name>
          <description>应用名称</description>
          <defaultValue>GameKu</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>OUTPUT_BASE_DIR</name>
          <description>输出基础目录</description>
          <defaultValue>/Users/wangling/Desktop/Builds</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>GIT_BRANCH</name>
          <description>Git 分支 (可选)</description>
          <defaultValue></defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
      </parameterDefinitions>
    </hudson.model.ParametersDefinitionProperty>
  </properties>
  <scm class="hudson.scm.NullSCM"/>
  <builders>
    <hudson.tasks.Shell>
      <command>#!/bin/bash
set -e

echo "======================================="
echo "  GameKu Android 构建 (Jenkins)"
echo "======================================="
echo ""
echo "构建参数:"
echo "  Unity 版本: $UNITY_VERSION"
echo "  版本号: $VERSION_NAME"
echo "  版本代码: $VERSION_CODE"
echo "  应用名称: $APP_NAME"
echo "  Git 分支: ${GIT_BRANCH:-默认}"

# 执行构建脚本
bash ~/build_gameku_android.sh</command>
    </hudson.tasks.Shell>
    <hudson.tasks.Shell>
      <command>#!/bin/bash
echo "=== 更新 Jenkins 参数默认值 ==="
bash ~/update_jenkins_params.sh || echo "参数更新失败（不影响构建结果）"</command>
    </hudson.tasks.Shell>
  </builders>
  <publishers/>
  <buildWrappers/>
</project>
