<?xml version='1.0' encoding='UTF-8'?>
<project>
  <description>GameKu iOS 构建 - 参数化构建任务</description>
  <keepDependencies>false</keepDependencies>
  <properties>
    <hudson.model.ParametersDefinitionProperty>
      <parameterDefinitions>
        <hudson.model.StringParameterDefinition>
          <name>UNITY_VERSION</name>
          <description>Unity 版本 (例如: 6000.3.8f1)</description>
          <defaultValue>6000.3.8f1</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>VERSION_NAME</name>
          <description>应用版本号 (例如: 1.0.0)</description>
          <defaultValue>1.0.0</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>VERSION_CODE</name>
          <description>应用版本代码</description>
          <defaultValue>100</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>APP_NAME</name>
          <description>应用名称</description>
          <defaultValue>GameKu</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>OUTPUT_BASE_DIR</name>
          <description>输出基础文件夹 (例如: /Users/wangling/Desktop/Builds)</description>
          <defaultValue>/Users/wangling/Desktop/Builds</defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>GIT_BRANCH</name>
          <description>Git 分支 (留空使用当前分支)</description>
          <defaultValue></defaultValue>
          <trim>true</trim>
        </hudson.model.StringParameterDefinition>
      </parameterDefinitions>
    </hudson.model.ParametersDefinitionProperty>
  </properties>
  <scm class="hudson.scm.NullSCM"/>
  <builders>
    <hudson.tasks.Shell>
      <command>#!/bin/bash
set -e

echo "======================================="
echo "  GameKu iOS 构建 (Jenkins)"
echo "======================================="
echo ""
echo "构建参数:"
echo "  Unity 版本: $UNITY_VERSION"
echo "  版本号: $VERSION_NAME"
echo "  版本代码: $VERSION_CODE"
echo "  应用名称: $APP_NAME"
echo "  输出目录: $OUTPUT_BASE_DIR"
echo "  Git 分支: ${GIT_BRANCH:-默认}"
echo ""

# TODO: iOS 构建脚本
echo "iOS 构建功能待实现"
echo "需要 Xcode 进行 iOS 打包"
exit 1</command>
    </hudson.tasks.Shell>
  </builders>
  <publishers>
    <hudson.tasks.ArtifactArchiver>
      <artifacts>**/*.ipa</artifacts>
      <allowEmptyArchive>false</allowEmptyArchive>
    </hudson.tasks.ArtifactArchiver>
  </publishers>
  <buildWrappers/>
</project>
