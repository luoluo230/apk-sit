    HOST = os.getenv('APK_HOST', '0.0.0.0')
    LOG_DIR = os.getenv('APK_LOG_DIR', os.path.join(os.path.dirname(__file__), 'logs'))
    DEBUG = os.getenv('APK_DEBUG', 'false').lower() == 'true'
    SECRET_KEY = os.getenv('APK_SECRET', secrets.token_hex(32))
    FORCE_LOGIN = os.getenv('FORCE_LOGIN', 'true').lower() == 'true'
    INNER_NET = os.getenv('INNER_NET', '192.168.,10.,127.,26.26.').split(',')
    IP_WHITELIST_RAW = os.getenv('IP_WHITELIST', '')
    IP_WHITELIST = [ip.strip() for ip in IP_WHITELIST_RAW.split(',') if ip.strip()] if IP_WHITELIST_RAW else None
    LOGIN_ATTEMPTS_LIMIT = 5
    LOGIN_LOCKOUT_MINUTES = 15

# 日志配置
def setup_logging():
    os.makedirs(Config.LOG_DIR, exist_ok=True)
    log_file = os.path.join(Config.LOG_DIR, f'app_{datetime.now().strftime("%Y%m%d")}.log')
    logging.basicConfig(
        level=logging.INFO,
        format='[%(asctime)s] %(levelname)s: %(message)s',
        handlers=[
            logging.FileHandler(log_file, encoding='utf-8'),
            logging.StreamHandler(sys.stdout)
        ]
    )
    return logging.getLogger(__name__)

logger = setup_logging()

# Flask 应用
