changelog_db = load_json(CHANGELOG_FILE, {})
audit_log_db = load_json(AUDIT_LOG_FILE, [])

def save_users():
    save_json(USERS_FILE, users_db)

def save_projects():
    save_json(PROJECTS_FILE, projects_db)

def save_stats():
    save_json(STATS_FILE, download_stats)

def save_login_attempts():
    save_json(LOGIN_ATTEMPTS_FILE, login_attempts)

def save_versions():
    save_json(VERSIONS_FILE, versions_db)

def save_changelog():
    save_json(CHANGELOG_FILE, changelog_db)

def save_audit_log():
    save_json(AUDIT_LOG_FILE, audit_log_db)

def log_audit(action, details=""):
    """记录操作日志"""
    entry = {
        'timestamp': datetime.now().isoformat(),
        'user': session.get('user', 'unknown'),
        'action': action,
        'details': details,
        'ip': request.remote_addr or '127.0.0.1'
    }
    audit_log_db.append(entry)
    save_audit_log()

# 安全工具函数
def is_inner_network(ip):
    if not ip:
        return False
    for prefix in Config.INNER_NET:
        prefix = prefix.strip()
        if prefix and ip.startswith(prefix):
            return True
    return False

def check_login_attempts(ip):
    now = datetime.now().timestamp()
    if ip not in login_attempts:
        return True, 0
    attempts = login_attempts[ip]
    locked_until = attempts.get('locked_until', 0)
    if locked_until > now:
        return False, attempts.get('attempts', 0)
    elif locked_until > 0 and locked_until <= now:
        login_attempts[ip] = {'attempts': 0, 'locked_until': 0}
        save_login_attempts()
    return True, attempts.get('attempts', 0)

def record_login_attempt(ip, success):
    now = datetime.now().timestamp()
    if ip not in login_attempts:
        login_attempts[ip] = {'attempts': 0, 'locked_until': 0}
    if success:
        login_attempts[ip] = {'attempts': 0, 'locked_until': 0}
        users_db[session.get('user')]['last_login'] = datetime.now().isoformat()
        save_users()
    else:
        login_attempts[ip]['attempts'] += 1
        if login_attempts[ip]['attempts'] >= Config.LOGIN_ATTEMPTS_LIMIT:
            login_attempts[ip]['locked_until'] = now + (Config.LOGIN_LOCKOUT_MINUTES * 60)
            logger.warning(f"IP {ip} 登录失败次数过多，已锁定 {Config.LOGIN_LOCKOUT_MINUTES} 分钟")
    save_login_attempts()

# 工具函数
def extract_project_name(filename):
    base = filename.replace('.apk', '')
    if '_' in base:
        return base.split('_')[0]
    return base

def parse_apk_metadata(apk_path):
    try:
        filename = os.path.basename(apk_path)
        base_name = filename.replace('.apk', '').replace('_', ' ')
        version_match = re.search(r'(\d+\.\d+\.\d+)', filename)
        version = version_match.group(1) if version_match else '1.0'
        app_name = base_name.title()
        return {
            'package': f'com.example.{base_name.replace(" ", "").lower()}',
            'version': version,
            'app_name': app_name
        }
    except Exception as e:
        logger.warning(f"解析 APK 失败 {apk_path}: {e}")
        return None

def extract_apk_info(filename, filepath):
    stat = os.stat(filepath)
    project_name = extract_project_name(filename)
    file_info = {
        'name': filename,
        'size': stat.st_size,
        'size_mb': f"{stat.st_size/1024/1024:.1f}MB",
        'date': datetime.fromtimestamp(stat.st_mtime).strftime('%Y-%m-%d %H:%M'),
        'timestamp': stat.st_mtime,
        'download_count': download_stats.get(filename, 0),
        'project': project_name
    }
    metadata = parse_apk_metadata(filepath)
    if metadata:
        file_info.update(metadata)
    else:
        file_info['app_name'] = filename.replace('.apk', '').replace('_', ' ').title()
        file_info['package'] = 'unknown'
        file_info['version'] = '1.0'
    return file_info

# 认证装饰器
def login_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if 'user' not in session:
            return redirect(url_for('login'))
        return f(*args, **kwargs)
    return decorated_function

def admin_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if 'user' not in session:
            return redirect(url_for('login'))
        user_info = users_db.get(session['user'])
        if not user_info or user_info.get('role') not in ['super_admin', 'admin']:
            abort(403)
        return f(*args, **kwargs)
    return decorated_function

def is_admin():
    username = session.get('user')
    if username and username in users_db:
        return users_db[username].get('role') in ['super_admin', 'admin']
    return False

# 辅助函数
def get_project_apk_count(project_id):
    count = 0
    if os.path.exists(Config.APK_DIR):
        for filename in os.listdir(Config.APK_DIR):
            if filename.endswith('.apk'):
                if extract_project_name(filename) == project_id:
                    count += 1
    return count

def get_total_downloads():
    return sum(download_stats.values())

def get_active_projects_count():
    active_projects = set()
    if os.path.exists(Config.APK_DIR):
        for filename in os.listdir(Config.APK_DIR):
            if filename.endswith('.apk'):
                project_name = extract_project_name(filename)
                active_projects.add(project_name)
    return len(active_projects)

