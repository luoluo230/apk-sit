@app.route('/admin/projects/create', methods=['POST'])
@admin_required
def create_project():
    data = request.json
    project_id = data.get('id')
    name = data.get('name')
    description = data.get('description', '')
    
    if not project_id or not name:
        return jsonify({'success': False, 'error': '项目ID和名称不能为空'})
    
    if project_id in projects_db:
        return jsonify({'success': False, 'error': '项目ID已存在'})
    
    projects_db[project_id] = {
        'name': name,
        'description': description,
        'created_at': datetime.now().isoformat(),
        'order': len(projects_db) + 1,
        'status': 'active'
    }
    save_projects()
    
    return jsonify({'success': True})

@app.route('/admin/projects/delete/<project_id>', methods=['DELETE'])
@admin_required
def delete_project(project_id):
    if project_id not in projects_db:
        return jsonify({'success': False, 'error': '项目不存在'})
    
    del projects_db[project_id]
    save_projects()
    
    return jsonify({'success': True})

# ==================== 数据分析仪表板 ====================

@app.route('/dashboard')
@login_required
def dashboard():
    """数据分析仪表板"""
    # 获取统计数据
    total_apks = 0
    total_size = 0
    project_stats = defaultdict(lambda: {'count': 0, 'size': 0, 'downloads': 0})
    
    if os.path.exists(Config.APK_DIR):
        for filename in os.listdir(Config.APK_DIR):
            if filename.endswith('.apk'):
                filepath = os.path.join(Config.APK_DIR, filename)
                if os.path.isfile(filepath):
                    stat = os.stat(filepath)
                    project_name = extract_project_name(filename)
                    downloads = download_stats.get(filename, 0)
                    
                    total_apks += 1
                    total_size += stat.st_size
                    project_stats[project_name]['count'] += 1
                    project_stats[project_name]['size'] += stat.st_size
                    project_stats[project_name]['downloads'] += downloads
    
    # 生成项目统计HTML
    project_html = ""
    for project_id, stats in project_stats.items():
        project_name = projects_db.get(project_id, {}).get('name', project_id)
        size_mb = stats['size'] / 1024 / 1024
        project_html += f"""
        <div class="bg-white rounded-lg shadow p-6 mb-4">
            <div class="flex justify-between items-center">
                <div>
                    <h3 class="text-lg font-bold">{project_name}</h3>
                    <div class="text-sm text-gray-600 mt-2">
                        <span class="mr-4">📦 {stats['count']} 个APK</span>
                        <span class="mr-4">💾 {size_mb:.1f} MB</span>
                        <span>⬇️ {stats['downloads']} 次下载</span>
                    </div>
                </div>
            </div>
        </div>
        """
    
    # 获取下载排行
    top_apks = sorted(download_stats.items(), key=lambda x: x[1], reverse=True)[:10]
    top_html = ""
    for i, (filename, downloads) in enumerate(top_apks, 1):
        top_html += f"""
        <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{i}</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{filename}</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{downloads}</td>
        </tr>
        """
    
    return f"""<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>数据分析 - APK 下载中心</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-gray-800">📊 数据分析仪表板</h1>
            <div class="flex gap-4">
                <a href="/" class="text-blue-600 hover:underline">首页</a>
                <a href="/logout" class="text-red-600 hover:underline">退出</a>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-600">总 APK 数</p>
                        <p class="text-2xl font-bold">{total_apks}</p>
                    </div>
                    <i class="fas fa-box-open text-blue-500 text-2xl"></i>
                </div>
            </div>
            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-600">总下载量</p>
                        <p class="text-2xl font-bold">{sum(download_stats.values())}</p>
                    </div>
                    <i class="fas fa-download text-green-500 text-2xl"></i>
                </div>
            </div>
            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-600">总大小</p>
                        <p class="text-2xl font-bold">{total_size/1024/1024:.1f} MB</p>
                    </div>
                    <i class="fas fa-hdd text-purple-500 text-2xl"></i>
                </div>
            </div>
            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-600">项目数</p>
                        <p class="text-2xl font-bold">{len(project_stats)}</p>
                    </div>
                    <i class="fas fa-folder text-orange-500 text-2xl"></i>
                </div>
            </div>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-lg font-bold mb-4">项目分布</h2>
                <canvas id="projectChart" height="300"></canvas>
            </div>
            
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-lg font-bold mb-4">下载排行 TOP 10</h2>
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">排名</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">文件名</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">下载次数</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {top_html}
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-bold mb-4">项目详情</h2>
            {project_html}
        </div>
    </div>
    
    <script>
        // 项目分布图表
        const ctx = document.getElementById('projectChart').getContext('2d');
        const projectData = {json_module.dumps(dict(project_stats))};
        const labels = Object.keys(projectData).map(id => projectData[id].name || id);
        const data = Object.values(projectData).map(d => d.count);
        
        new Chart(ctx, {{
            type: 'doughnut',
            data: {{
                labels: labels,
                datasets: [{{
                    data: data,
                    backgroundColor: [
                        '#3B82F6', '#10B981', '#F59E0B', '#EF4444', '#8B5CF6',
                        '#EC4899', '#06B6D4', '#84CC16', '#F97316', '#6366F1'
                    ]
                }}]
            }},
            options: {{
                responsive: true,
                maintainAspectRatio: false,
                plugins: {{
                    legend: {{
                        position: 'bottom'
                    }}
                }}
            }}
        }});
    </script>
</body>
</html>
"""

# ==================== API 接口 ====================

@app.route('/api/apks')
@login_required
def api_list_apks():
    """API: 获取APK列表"""
    files = []
    if os.path.exists(Config.APK_DIR):
        for filename in os.listdir(Config.APK_DIR):
            if filename.endswith('.apk'):
                filepath = os.path.join(Config.APK_DIR, filename)
                if os.path.isfile(filepath):
                    files.append(extract_apk_info(filename, filepath))
    return jsonify({'success': True, 'data': files})

@app.route('/api/stats')
@login_required
def api_stats():
    """API: 获取统计数据"""
    return jsonify({
        'success': True,
        'data': {
            'total_apks': len([f for f in os.listdir(Config.APK_DIR) if f.endswith('.apk')]) if os.path.exists(Config.APK_DIR) else 0,
            'total_downloads': sum(download_stats.values()),
            'projects': len(projects_db)
        }
    })

# ==================== 操作日志审计 ====================

@app.route('/admin/audit-log')
@admin_required
def admin_audit_log():
    """操作日志审计页面"""
    log_html = ""
    for entry in reversed(audit_log_db[-100:]):  # 最近100条
        action_class = {
            'login': 'bg-blue-100 text-blue-800',
            'upload': 'bg-green-100 text-green-800',
            'delete': 'bg-red-100 text-red-800',
            'create_user': 'bg-purple-100 text-purple-800',
            'create_project': 'bg-orange-100 text-orange-800',
            'download': 'bg-gray-100 text-gray-800'
        }.get(entry.get('action', ''), 'bg-gray-100 text-gray-800')
        
        log_html += f"""
        <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{entry.get('timestamp', '-')[:19]}</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{entry.get('user', '-')}</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
                <span class="px-2 py-1 rounded-full text-xs font-semibold {action_class}">{entry.get('action', '-')}</span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">{entry.get('details', '-')}</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{entry.get('ip', '-')}</td>
        </tr>
        """
    
    return f"""<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>操作日志 - APK 下载中心</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-gray-800">📋 操作日志审计</h1>
            <div class="flex gap-4">
                <a href="/admin" class="text-blue-600 hover:underline">← 返回管理中心</a>
                <a href="/" class="text-blue-600 hover:underline">首页</a>
            </div>
        </div>
        
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <div class="p-4 border-b">
                <h2 class="text-lg font-semibold">最近100条操作记录</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">时间</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">用户</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">操作</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">详情</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">IP</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {log_html if log_html else '<tr><td colspan="5" class="px-6 py-4 text-center text-gray-500">暂无操作记录</td></tr>'}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
"""

# ==================== 版本管理 ====================

@app.route('/admin/versions')
@admin_required
def admin_versions():
    """版本管理页面"""
    try:
        versions_html = ""
        
        # 按项目分组APK
        project_versions = defaultdict(list)
        if os.path.exists(Config.APK_DIR):
            for filename in os.listdir(Config.APK_DIR):
                if filename.endswith('.apk'):
                    filepath = os.path.join(Config.APK_DIR, filename)
                    if os.path.isfile(filepath):
                        info = extract_apk_info(filename, filepath)
                        project_versions[info['project']].append(info)
        
        for project_id, apks in project_versions.items():
            project_name = projects_db.get(project_id, {}).get('name', project_id)
            apks.sort(key=lambda x: x['timestamp'], reverse=True)
            
            apk_list = ""
            for apk in apks:
                changelog = changelog_db.get(apk['name'], '暂无更新说明')
                apk_list += f"""
                <div class="border rounded-lg p-4 mb-2">
                    <div class="flex justify-between items-center">
                        <div>
                            <span class="font-medium">{apk['name']}</span>
                            <span class="ml-2 text-sm text-gray-500">v{apk['version']}</span>
                            <span class="ml-2 text-sm text-gray-500">{apk['size_mb']}</span>
                        </div>
                        <div class="text-sm text-gray-500">{apk['date']}</div>
                    </div>
                    <div class="mt-2 text-sm text-gray-600">{changelog}</div>
                </div>
                """
            
            versions_html += f"""
            <div class="bg-white rounded-lg shadow mb-6">
                <div class="p-4 border-b bg-gray-50">
                    <h3 class="font-bold text-lg">📁 {project_name}</h3>
                </div>
                <div class="p-4">
                    {apk_list if apk_list else '<p class="text-gray-500">暂无版本</p>'}
                </div>
            </div>
            """
        
        return f"""<!DOCTYPE html>
    <html lang="zh-CN">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>版本管理 - APK 下载中心</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    </head>
    <body class="bg-gray-50 min-h-screen">
        <div class="container mx-auto px-4 py-8">
            <div class="flex justify-between items-center mb-6">
                <h1 class="text-3xl font-bold text-gray-800">📦 版本管理</h1>
                <div class="flex gap-4">
                    <a href="/admin" class="text-blue-600 hover:underline">← 返回管理中心</a>
                    <a href="/" class="text-blue-600 hover:underline">首页</a>
                </div>
            </div>
            
            {versions_html if versions_html else '<div class="bg-white rounded-lg shadow p-8 text-center text-gray-500">暂无APK文件</div>'}
        </div>
    </body>
    </html>
    """
    except Exception as e:
        logger.error(f"版本管理页面加载失败：{e}", exc_info=True)
        abort(500)

@app.route('/admin/changelog/<filename>', methods=['POST'])
@admin_required
def update_changelog(filename):
    """更新版本说明"""
    data = request.json
    changelog = data.get('changelog', '')
    
    changelog_db[filename] = changelog
    save_changelog()
    log_audit('update_changelog', f'更新 {filename} 的版本说明')
    
    return jsonify({'success': True})

