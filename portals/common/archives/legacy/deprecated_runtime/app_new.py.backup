# 路由 - 主页
@app.route('/')
@login_required
def index():
    files = []
    total_size = 0
    
    try:
        if os.path.exists(Config.APK_DIR):
            for filename in os.listdir(Config.APK_DIR):
                if filename.endswith('.apk'):
                    filepath = os.path.join(Config.APK_DIR, filename)
                    if os.path.isfile(filepath):
                        file_info = extract_apk_info(filename, filepath)
                        files.append(file_info)
                        total_size += file_info['size']
        
        grouped_files = defaultdict(list)
        for f in files:
            grouped_files[f['project']].append(f)
        
        for project in grouped_files:
            grouped_files[project].sort(key=lambda x: x['timestamp'], reverse=True)
        
        # 生成文件列表HTML
        files_html = ""
        for project_id, project_files in grouped_files.items():
            project_name = projects_db.get(project_id, {}).get('name', project_id)
            files_html += f"""
            <div class="project-group" data-project="{project_id}">
                <div class="p-4 bg-gray-50">
                    <h3 class="font-bold">📁 {project_name}</h3>
                </div>
            """
            for f in project_files:
                files_html += f"""
                <div class="file-item p-4 hover:bg-gray-50" data-name="{f['name'].lower()}">
                    <div class="flex justify-between items-center">
                        <div>
                            <div class="font-bold">{f['name']}</div>
                            <div class="text-sm text-gray-600">{f['app_name']} • v{f['version']} • {f['size_mb']} • {f['date']}</div>
                        </div>
                        <div class="flex gap-2">
                            <button onclick="showQR('{f['name']}')" class="px-3 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600">
                                <i class="fas fa-qrcode"></i>
                            </button>
                            <a href="/download/{f['name']}" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">下载</a>
                        </div>
                    </div>
                </div>
                """
            files_html += "</div>"
        
        total_size_mb = total_size / 1024 / 1024 if total_size > 0 else 0
        current_user = session.get('user', 'admin')
        
        admin_link = '<a href="/admin" class="text-sm text-blue-600 hover:underline">管理中心</a>' if is_admin() else ''
        upload_btn = '<button onclick="showUploadModal()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700"><i class="fas fa-upload"></i> 上传APK</button>' if is_admin() else ''
        
        return render_template_string(
            HTML_TEMPLATE.format(
                files_html=files_html,
                total_count=len(files),
                total_size_mb=f"{total_size_mb:.1f}",
                current_user=current_user,
                admin_link=admin_link,
                upload_btn=upload_btn,
                total_downloads=get_total_downloads(),
                active_projects=get_active_projects_count()
            ),
            files=files,
            total_count=len(files),
            total_size_mb=f"{total_size_mb:.1f}",
            current_user=current_user,
            admin_link=admin_link,
            upload_btn=upload_btn,
            total_downloads=get_total_downloads(),
            active_projects=get_active_projects_count()
        )
        
    except Exception as e:
        logger.error(f"首页加载失败：{e}", exc_info=True)
        abort(500)

# 路由 - 登录
@app.route('/login', methods=['GET', 'POST'])
def login():
    client_ip = request.remote_addr or '127.0.0.1'
    
    if request.method == 'POST':
        allowed, attempts = check_login_attempts(client_ip)
        if not allowed:
            remaining_time = int((login_attempts[client_ip]['locked_until'] - datetime.now().timestamp()) / 60) + 1
            locked_msg = f'<div class="bg-yellow-100 text-yellow-700 p-3 rounded mb-4">登录次数过多，请 {remaining_time} 分钟后再试</div>'
            return render_template_string(LOGIN_TEMPLATE, error_msg='', locked_msg=locked_msg)
        
        username = request.form.get('username')
        password = request.form.get('password')
        
        if username in users_db:
            password_hash = hashlib.sha256(password.encode()).hexdigest()
            if users_db[username]['password'] == password_hash:
                session['user'] = username
                record_login_attempt(client_ip, True)
                logger.info(f"用户 {username} 登录成功 (IP: {client_ip})")
                return redirect(url_for('index'))
        
        record_login_attempt(client_ip, False)
        logger.warning(f"登录失败：{username} (IP: {client_ip})")
        error_msg = '<div class="bg-red-100 text-red-700 p-3 rounded mb-4">用户名或密码错误</div>'
        return render_template_string(LOGIN_TEMPLATE, error_msg=error_msg, locked_msg='')
    
    allowed, attempts = check_login_attempts(client_ip)
    locked = not allowed
    locked_msg = ''
    if locked:
        lockout_time = int((login_attempts[client_ip]['locked_until'] - datetime.now().timestamp()) / 60) + 1
        locked_msg = f'<div class="bg-yellow-100 text-yellow-700 p-3 rounded mb-4">登录次数过多，请 {lockout_time} 分钟后再试</div>'
    
    return render_template_string(LOGIN_TEMPLATE, error_msg='', locked_msg=locked_msg)

# 路由 - 退出
@app.route('/logout')
def logout():
    session.pop('user', None)
    return redirect(url_for('index'))

# 路由 - 下载
@app.route('/download/<path:filename>')
@login_required
def download(filename):
    client_ip = request.remote_addr or '127.0.0.1'
    logger.info(f"下载请求：{filename}, IP: {client_ip}")
    
    if '..' in filename or filename.startswith('/'):
        abort(403)
    
    if not filename.lower().endswith('.apk'):
        abort(403)
    
    safe_filename = os.path.basename(filename)
    filepath = os.path.join(Config.APK_DIR, safe_filename)
    
    if not os.path.exists(filepath):
        abort(404)
    
    download_stats[safe_filename] = download_stats.get(safe_filename, 0) + 1
    save_stats()
    
    return send_from_directory(Config.APK_DIR, safe_filename, as_attachment=True)

# 路由 - 二维码
@app.route('/qr/<path:filename>')
@login_required
def generate_qr(filename):
    host = request.host.split(':')[0]
    port = request.host.split(':')[1] if ':' in request.host else str(Config.PORT)
    download_url = f"http://{host}:{port}/download/{filename}"
    
    qr = qrcode.QRCode(version=1, error_correction=qrcode.constants.ERROR_CORRECT_L, box_size=10, border=4)
    qr.add_data(download_url)
    qr.make(fit=True)
    
    img = qr.make_image(fill_color="black", back_color="white")
    
    img_io = io.BytesIO()
    img.save(img_io, 'PNG')
    img_io.seek(0)
    
    img_base64 = base64.b64encode(img_io.getvalue()).decode()
    
    return jsonify({'qr_code': f'data:image/png;base64,{img_base64}', 'url': download_url})

# 路由 - 健康检查
@app.route('/health')
def health():
    apk_count = len([f for f in os.listdir(Config.APK_DIR) if f.endswith('.apk')]) if os.path.exists(Config.APK_DIR) else 0
    return jsonify({'status': 'ok', 'apk_count': apk_count, 'timestamp': datetime.now().isoformat()})

# 路由 - APK上传
@app.route('/upload', methods=['POST'])
@admin_required
def upload_apk():
    """上传APK文件"""
    try:
        if 'file' not in request.files:
            return jsonify({'success': False, 'error': '没有选择文件'})
        
        file = request.files['file']
        if file.filename == '':
            return jsonify({'success': False, 'error': '没有选择文件'})
        
        if not file.filename.lower().endswith('.apk'):
            return jsonify({'success': False, 'error': '只允许上传APK文件'})
        
        # 确保目录存在
        os.makedirs(Config.APK_DIR, exist_ok=True)
        
        # 保存文件
        filename = file.filename
        filepath = os.path.join(Config.APK_DIR, filename)
        file.save(filepath)
        
        logger.info(f"上传APK成功: {filename}")
        return jsonify({'success': True, 'filename': filename})
        
    except Exception as e:
        logger.error(f"上传APK失败: {e}")
        return jsonify({'success': False, 'error': str(e)})

# 路由 - 删除APK
@app.route('/delete/<path:filename>', methods=['DELETE'])
@admin_required
def delete_apk(filename):
    """删除APK文件"""
    try:
        if '..' in filename or filename.startswith('/'):
            return jsonify({'success': False, 'error': '非法文件名'})
        
        safe_filename = os.path.basename(filename)
        filepath = os.path.join(Config.APK_DIR, safe_filename)
        
        if not os.path.exists(filepath):
            return jsonify({'success': False, 'error': '文件不存在'})
        
        os.remove(filepath)
        
        # 删除下载统计
        if safe_filename in download_stats:
            del download_stats[safe_filename]
            save_stats()
        
        logger.info(f"删除APK成功: {safe_filename}")
        return jsonify({'success': True})
        
    except Exception as e:
        logger.error(f"删除APK失败: {e}")
        return jsonify({'success': False, 'error': str(e)})

