# ============================================================================
# 路由
# ============================================================================
@app.route('/')
@login_required
def index():
    files = []
    total_size = 0
    
    try:
        if os.path.exists(Config.APK_DIR):
            for filename in os.listdir(Config.APK_DIR):
                if filename.endswith('.apk'):
                    filepath = os.path.join(Config.APK_DIR, filename)
                    if os.path.isfile(filepath):
                        file_info = extract_apk_info(filename, filepath)
                        files.append(file_info)
                        total_size += file_info['size']
        
        # 按项目分组
        grouped_files = defaultdict(list)
        for f in files:
            grouped_files[f['project']].append(f)
        
        # 排序
        for project in grouped_files:
            grouped_files[project].sort(key=lambda x: x['timestamp'], reverse=True)
        
        total_size_mb = total_size / 1024 / 1024 if total_size > 0 else 0
        
        # 检查用户权限
        current_user = session.get('user', 'admin')
        user_info = users_db.get(current_user, {})
        is_admin = user_info.get('role') == 'super_admin'
        
        return render_template_string(
            HTML_TEMPLATE,
            files=files,
            grouped_files=grouped_files,
            projects=projects_db,
            total_count=len(files),
            total_size_mb=f"{total_size_mb:.1f}",
            current_user=current_user,
            is_admin=is_admin
        )
        
    except Exception as e:
        logger.error(f"首页加载失败：{e}", exc_info=True)
        abort(500)

@app.route('/login', methods=['GET', 'POST'])
def login():
    client_ip = request.remote_addr or '127.0.0.1'
    
    if request.method == 'POST':
        # 检查登录限制
        allowed, attempts = check_login_attempts(client_ip)
        if not allowed:
            remaining_time = int((login_attempts[client_ip]['locked_until'] - datetime.now().timestamp()) / 60) + 1
            return render_template_string(LOGIN_TEMPLATE, error=f"登录尝试次数过多", locked=True, lockout_time=remaining_time)
        
        username = request.form.get('username')
        password = request.form.get('password')
        
        if username in users_db:
            password_hash = hashlib.sha256(password.encode()).hexdigest()
            if users_db[username]['password'] == password_hash:
                # 登录成功
                session['user'] = username
                record_login_attempt(client_ip, True)
                logger.info(f"用户 {username} 登录成功 (IP: {client_ip})")
                return redirect(url_for('index'))
        
        # 登录失败
        record_login_attempt(client_ip, False)
        logger.warning(f"登录失败：{username} (IP: {client_ip})")
        return render_template_string(LOGIN_TEMPLATE, error="用户名或密码错误")
    
    # GET 请求，检查是否被锁定
    allowed, attempts = check_login_attempts(client_ip)
    locked = not allowed
    lockout_time = 0
    if locked:
        lockout_time = int((login_attempts[client_ip]['locked_until'] - datetime.now().timestamp()) / 60) + 1
    
    return render_template_string(LOGIN_TEMPLATE, locked=locked, lockout_time=lockout_time)

@app.route('/logout')
def logout():
    session.pop('user', None)
    return redirect(url_for('index'))

@app.route('/download/<path:filename>')
@login_required
def download(filename):
    client_ip = request.remote_addr or '127.0.0.1'
    logger.info(f"下载请求：{filename}, IP: {client_ip}")
    
    if '..' in filename or filename.startswith('/'):
        abort(403)
    
    if not filename.lower().endswith('.apk'):
        abort(403)
    
    safe_filename = os.path.basename(filename)
    filepath = os.path.join(Config.APK_DIR, safe_filename)
    
    if not os.path.exists(filepath):
        abort(404)
    
    download_stats[safe_filename] = download_stats.get(safe_filename, 0) + 1
    save_stats()
    
    return send_from_directory(Config.APK_DIR, safe_filename, as_attachment=True)

@app.route('/qr/<path:filename>')
@login_required
def generate_qr(filename):
    """生成二维码图片"""
    # 生成下载链接
    download_url = f"http://{request.host}/download/{filename}"
    
    # 生成二维码
    qr = qrcode.QRCode(
        version=1,
        error_correction=qrcode.constants.ERROR_CORRECT_L,
        box_size=10,
        border=4,
    )
    qr.add_data(download_url)
    qr.make(fit=True)
    
    img = qr.make_image(fill_color="black", back_color="white")
    
    # 转换为 PNG 格式
    img_io = io.BytesIO()
    img.save(img_io, 'PNG')
    img_io.seek(0)
    
    # 转换为 base64
    img_base64 = base64.b64encode(img_io.getvalue()).decode()
    
    return jsonify({'qr_code': f'data:image/png;base64,{img_base64}', 'url': download_url})

@app.route('/health')
def health():
    apk_count = len([f for f in os.listdir(Config.APK_DIR) if f.endswith('.apk')]) if os.path.exists(Config.APK_DIR) else 0
    return jsonify({
        'status': 'ok',
        'apk_count': apk_count,
        'timestamp': datetime.now().isoformat()
    })

# ============================================================================
# 管理员接口
# ============================================================================
@app.route('/admin/users')
@admin_required
def admin_users():
    return jsonify(users_db)

@app.route('/admin/projects')
@admin_required
def admin_projects():
    return jsonify(projects_db)

@app.route('/admin/add_project', methods=['POST'])
@admin_required
def add_project():
    data = request.json
    project_id = data.get('id')
    project_name = data.get('name')
    description = data.get('description', '')
    
    if not project_id or not project_name:
        return jsonify({'error': '缺少必要参数'}), 400
    
    projects_db[project_id] = {
        'name': project_name,
        'description': description,
        'created_at': datetime.now().isoformat(),
        'order': len(projects_db) + 1
    }
    save_projects()
    
    return jsonify({'success': True})

@app.route('/admin/delete_project/<project_id>', methods=['DELETE'])
@admin_required
def delete_project(project_id):
    if project_id in projects_db:
        del projects_db[project_id]
        save_projects()
        return jsonify({'success': True})
    return jsonify({'error': '项目不存在'}), 404

