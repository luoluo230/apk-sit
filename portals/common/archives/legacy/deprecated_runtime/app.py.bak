#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
APK 下载站 - 专业版 (页签 + 权限管理 + 安全加固)
功能：项目页签、用户认证、IP 白名单、登录限制、增删改管理
"""

import os
import sys
import json
import logging
import zipfile
import re
import socket
import hashlib
import secrets
import time
import io
import base64
from datetime import datetime, timedelta
from pathlib import Path
from flask import Flask, render_template_string, send_from_directory, abort, request, jsonify, session, redirect, url_for
from functools import wraps
from collections import defaultdict
import qrcode
from PIL import Image

# ============================================================================
# 配置管理
# ============================================================================
class Config:
    APK_DIR = os.getenv('APK_DIR', '/Users/wangling/Desktop/Builds')
    PORT = int(os.getenv('APK_PORT', '5002'))
    HOST = os.getenv('APK_HOST', '0.0.0.0')
    LOG_DIR = os.getenv('APK_LOG_DIR', os.path.join(os.path.dirname(__file__), 'logs'))
    DEBUG = os.getenv('APK_DEBUG', 'false').lower() == 'true'
    SECRET_KEY = os.getenv('APK_SECRET', secrets.token_hex(32))
    
    # 强制所有访问都需要登录
    FORCE_LOGIN = os.getenv('FORCE_LOGIN', 'true').lower() == 'true'
    
    # 内网 IP 段（可配置）
    INNER_NET = os.getenv('INNER_NET', '192.168.,10.,127.,26.26.').split(',')
    
    # IP 白名单（逗号分隔，留空则使用内网 IP 段）
    IP_WHITELIST_RAW = os.getenv('IP_WHITELIST', '')
    IP_WHITELIST = [ip.strip() for ip in IP_WHITELIST_RAW.split(',') if ip.strip()] if IP_WHITELIST_RAW else None
    
    # 登录限制
    LOGIN_ATTEMPTS_LIMIT = 5  # 最大失败次数
    LOGIN_LOCKOUT_MINUTES = 15  # 锁定时间（分钟）

# ============================================================================
# 日志配置
# ============================================================================
def setup_logging():
    os.makedirs(Config.LOG_DIR, exist_ok=True)
    log_file = os.path.join(Config.LOG_DIR, f'app_{datetime.now().strftime("%Y%m%d")}.log')
    logging.basicConfig(
        level=logging.INFO,
        format='[%(asctime)s] %(levelname)s: %(message)s',
        handlers=[
            logging.FileHandler(log_file, encoding='utf-8'),
            logging.StreamHandler(sys.stdout)
        ]
    )
    return logging.getLogger(__name__)

logger = setup_logging()

# ============================================================================
# Flask 应用
# ============================================================================
app = Flask(__name__)
app.secret_key = Config.SECRET_KEY
app.config['MAX_CONTENT_LENGTH'] = 100 * 1024 * 1024

# 数据文件
DATA_DIR = os.path.join(os.path.dirname(__file__), 'data')
USERS_FILE = os.path.join(DATA_DIR, 'users.json')
PROJECTS_FILE = os.path.join(DATA_DIR, 'projects.json')
STATS_FILE = os.path.join(DATA_DIR, 'download_stats.json')
LOGIN_ATTEMPTS_FILE = os.path.join(DATA_DIR, 'login_attempts.json')

os.makedirs(DATA_DIR, exist_ok=True)

# ============================================================================
# 数据管理
# ============================================================================
def load_json(filepath, default={}):
    if os.path.exists(filepath):
        try:
            with open(filepath, 'r', encoding='utf-8') as f:
                return json.load(f)
        except:
            return default
    return default

def save_json(filepath, data):
    os.makedirs(os.path.dirname(filepath), exist_ok=True)
    with open(filepath, 'w', encoding='utf-8') as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

# 初始化数据
users_db = load_json(USERS_FILE, {
    'admin': {
        'password': hashlib.sha256('admin123'.encode()).hexdigest(),
        'role': 'super_admin',
        'created_at': datetime.now().isoformat()
    }
})

projects_db = load_json(PROJECTS_FILE, {
    'RecycleTycoon': {
        'name': '垃圾回收站',
        'description': '垃圾回收站游戏',
        'created_at': datetime.now().isoformat(),
        'order': 1
    }
})

download_stats = load_json(STATS_FILE, {})
login_attempts = load_json(LOGIN_ATTEMPTS_FILE, {})

def save_users():
    save_json(USERS_FILE, users_db)

def save_projects():
    save_json(PROJECTS_FILE, projects_db)

def save_stats():
    save_json(STATS_FILE, download_stats)

def save_login_attempts():
    save_json(LOGIN_ATTEMPTS_FILE, login_attempts)

# ============================================================================
# 安全工具函数
# ============================================================================
def is_whitelisted_ip(ip):
    """检查 IP 是否在白名单中"""
    if Config.IP_WHITELIST:
        return ip in Config.IP_WHITELIST
    return is_inner_network(ip)

def is_inner_network(ip):
    """判断是否为内网 IP"""
    if not ip:
        return False
    for prefix in Config.INNER_NET:
        prefix = prefix.strip()
        if prefix and ip.startswith(prefix):
            return True
    return False

def check_login_attempts(ip):
    """检查 IP 的登录尝试次数，返回 (是否允许尝试，失败次数)"""
    now = datetime.now().timestamp()
    
    if ip not in login_attempts:
        return True, 0
    
    attempts = login_attempts[ip]
    locked_until = attempts.get('locked_until', 0)
    
    if locked_until > now:
        # 仍在锁定期
        return False, attempts.get('attempts', 0)
    elif locked_until > 0 and locked_until <= now:
        # 锁定期已过，重置
        login_attempts[ip] = {'attempts': 0, 'locked_until': 0}
        save_login_attempts()
    
    return True, attempts.get('attempts', 0)

def record_login_attempt(ip, success):
    """记录登录尝试"""
    now = datetime.now().timestamp()
    
    if ip not in login_attempts:
        login_attempts[ip] = {'attempts': 0, 'locked_until': 0}
    
    if success:
        # 登录成功，清空记录
        login_attempts[ip] = {'attempts': 0, 'locked_until': 0}
    else:
        # 登录失败，增加计数
        login_attempts[ip]['attempts'] += 1
        
        if login_attempts[ip]['attempts'] >= Config.LOGIN_ATTEMPTS_LIMIT:
            # 超过限制，锁定
            login_attempts[ip]['locked_until'] = now + (Config.LOGIN_LOCKOUT_MINUTES * 60)
            logger.warning(f"IP {ip} 登录失败次数过多，已锁定 {Config.LOGIN_LOCKOUT_MINUTES} 分钟")
    
    save_login_attempts()

# ============================================================================
# 工具函数
# ============================================================================
def extract_project_name(filename):
    """从文件名提取项目名"""
    base = filename.replace('.apk', '')
    if '_' in base:
        return base.split('_')[0]
    return base

def parse_apk_metadata(apk_path):
    """解析 APK 元数据"""
    try:
        filename = os.path.basename(apk_path)
        base_name = filename.replace('.apk', '').replace('_', ' ')
        version_match = re.search(r'(\d+\.\d+\.\d+)', filename)
        version = version_match.group(1) if version_match else '1.0'
        app_name = base_name.title()
        return {
            'package': f'com.example.{base_name.replace(" ", "").lower()}',
            'version': version,
            'app_name': app_name
        }
    except Exception as e:
        logger.warning(f"解析 APK 失败 {apk_path}: {e}")
        return None

def extract_apk_info(filename, filepath):
    """提取 APK 文件信息"""
    stat = os.stat(filepath)
    project_name = extract_project_name(filename)
    
    file_info = {
        'name': filename,
        'size': stat.st_size,
        'size_mb': f"{stat.st_size/1024/1024:.1f}MB",
        'date': datetime.fromtimestamp(stat.st_mtime).strftime('%Y-%m-%d %H:%M'),
        'timestamp': stat.st_mtime,
        'download_count': download_stats.get(filename, 0),
        'project': project_name
    }
    
    metadata = parse_apk_metadata(filepath)
    if metadata:
        file_info.update(metadata)
    else:
        file_info['app_name'] = filename.replace('.apk', '').replace('_', ' ').title()
        file_info['package'] = 'unknown'
        file_info['version'] = '1.0'
    
    return file_info

# ============================================================================
# 认证装饰器
# ============================================================================
def login_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if 'user' not in session:
            return redirect(url_for('login'))
        return f(*args, **kwargs)
    return decorated_function

def admin_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if 'user' not in session:
            return redirect(url_for('login'))
        user_info = users_db.get(session['user'])
        if not user_info or user_info.get('role') != 'super_admin':
            abort(403)
        return f(*args, **kwargs)
    return decorated_function

