# Local secrets and environment files
.env
.env.*
!.env.example
jenkins_credentials.json
config/settings.json
data/secret.key
data/secret.key.not-so-secret

# Python cache and virtual env
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Node dependencies and build cache
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Project runtime logs and backups
logs/
backups/
*.log
*.out
*.err

# Runtime pid/lock/temp artifacts
*.pid
*.pid.lock
*.tmp
*.temp

# Database local runtime artifacts
*.db-wal
*.db-shm

# Common local output folders
portals/common/core/runtime/
portals/common/core/tmp/
portals/common/tmp/

# Optional user-generated local work directories
# data/workspaces/
# data/doc_attachments/
